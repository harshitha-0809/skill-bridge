# Render sets DATABASE_URL automatically from the linked Postgres database.
# For local dev you can use SQLite:
DATABASE_URL=sqlite:///./skillbridge.db

# Generate a strong random secret for production (Render can auto-generate this)
SECRET_KEY=change-this-to-a-long-random-string

ALGORITHM=HS256
ACCESS_TOKEN_EXPIRE_MINUTES=1440

# Set this to your Vercel frontend URL after deploying
FRONTEND_URL=https://your-app.vercel.app
